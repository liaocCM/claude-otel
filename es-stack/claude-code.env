# Source this in the shell where you run `claude`:   source claude-code.env
#
# Sends Claude Code telemetry to the local OTel Collector (grpc :4317).

# --- enable ---
export CLAUDE_CODE_ENABLE_TELEMETRY=1
export CLAUDE_CODE_ENHANCED_TELEMETRY_BETA=1   # enables traces (beta)
export CLAUDE_CODE_PROPAGATE_TRACEPARENT=1     # propagate W3C trace context
export OTEL_TRACES_EXPORTER=otlp               # (also set below) ensure spans export
export OTEL_TRACES_EXPORT_INTERVAL=3000        # flush spans quickly for the demo

# --- exporters ---
export OTEL_METRICS_EXPORTER=otlp
export OTEL_LOGS_EXPORTER=otlp
export OTEL_TRACES_EXPORTER=otlp

# --- where to send ---
export OTEL_EXPORTER_OTLP_PROTOCOL=grpc
export OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# --- faster export so the demo feels live (defaults: 60s metrics / 5s logs) ---
export OTEL_METRIC_EXPORT_INTERVAL=10000
export OTEL_LOGS_EXPORT_INTERVAL=5000

# --- richer events for the demo (PRIVACY: logs prompt text + tool args/commands) ---
export OTEL_LOG_USER_PROMPTS=1
export OTEL_LOG_TOOL_DETAILS=1

# --- tag every signal so it's easy to filter in Kibana ---
# Note: Claude Code filters `data_stream.*` out of this var, so we cannot change
# the data stream name from here. All Claude Code signals land in:
#   logs-generic.otel-default / metrics-generic.otel-default / traces-generic.otel-default
# Filter by these attrs in Kibana (KQL: resource.attributes.service.namespace : "claude-code-demo").
export OTEL_RESOURCE_ATTRIBUTES="service.namespace=claude-code-demo,deployment.environment=dev"
