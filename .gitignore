# --- Node / Vite (observability-explainer) ----------------------------------
node_modules/
dist/
.vite/
*.log
npm-debug.log*

# Vite's local-only env override convention. The committed `claude-code.env`
# files ARE meant to be tracked — they're the demo config, not secrets.
*.env.local
*.env.*.local

# --- Python -----------------------------------------------------------------
__pycache__/
*.pyc

