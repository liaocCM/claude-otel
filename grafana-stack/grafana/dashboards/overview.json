{
  "title": "Claude Code · Overview",
  "uid": "claude-code-overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "type": "stat",
      "title": "Total tokens",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 5 },
      "targets": [{ "expr": "sum(claude_code_token_usage_tokens_total)", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat",
      "title": "Total cost (USD)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 5 },
      "targets": [{ "expr": "sum(claude_code_cost_usage_USD_total)", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat",
      "title": "Sessions",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 5 },
      "targets": [{ "expr": "sum(claude_code_session_count_total)", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat",
      "title": "Lines of code",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 5 },
      "targets": [{ "expr": "sum(claude_code_lines_of_code_count_total)", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "timeseries",
      "title": "Token usage by type",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 8 },
      "targets": [{
        "expr": "sum by (type) (rate(claude_code_token_usage_tokens_total[5m]))",
        "legendFormat": "{{type}}",
        "refId": "A"
      }]
    },
    {
      "type": "timeseries",
      "title": "Cost over time (by model)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 8 },
      "targets": [{
        "expr": "sum by (model) (rate(claude_code_cost_usage_USD_total[5m]))",
        "legendFormat": "{{model}}",
        "refId": "A"
      }],
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } }
    },
    {
      "type": "logs",
      "title": "Recent Claude Code events",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 0, "y": 13, "w": 24, "h": 10 },
      "targets": [{
        "expr": "{service_name=\"claude-code\"}",
        "refId": "A"
      }],
      "options": {
        "showTime": true,
        "wrapLogMessage": true
      }
    }
  ]
}
